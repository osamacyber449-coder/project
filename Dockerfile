# المرحلة الأولى: استخدام نسخة مستقرة ومصغرة ومعتمدة أمنياً من خادم Nginx
FROM nginx:1.25-alpine

# إعداد المتغيرات البيئية لإيقاف إظهار إصدار الخادم في الترويسات (حماية من تسريب البيانات)
ENV NGINX_VERSION_SECURITY_HEADER=off

# تعيين مسار العمل الافتراضي الذي يقرأ منه Nginx الملفات للجمهور
WORKDIR /usr/share/nginx/html

# تنظيف المجلد من أي ملفات ترحيبية افتراضية قد تحتوي على معلومات عن الخادم
RUN rm -rf ./*

# نسخ ملفات مشروعك بالكامل (HTML, JS, CSS) إلى داخل مجلد الحاوية المعزول
COPY index.html .
COPY script.js .
COPY style.css .

# تفعيل صلاحيات القراءة فقط للملفات لضمان عدم التعديل عليها أثناء التشغيل
RUN chmod 644 index.html script.js style.css

# فتح المنفذ 80 داخل الحاوية لاستقبال الترافيك
EXPOSE 80

# تشغيل الخادم في الواجهة الأمامية بشكل دائم لضمان استقرار الحاوية
CMD ["nginx", "-g", "daemon off;"]
